{
  "name": "ecommerce",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "server": "nodemon index.js",
    "client": "cd frontend && npm run dev",

    "fullstack": "concurrently \"npm run server\" \"npm run client\"",

    "fullstack:dev": "cross-env NODE_ENV=development concurrently \"npm run server\" \"npm run client\"",
    "fullstack:prod": "cross-env NODE_ENV=production concurrently \"npm run server\" \"npm run client\"",

    "dev": "cross-env NODE_ENV=development nodemon index.js",
    "prod": "cross-env NODE_ENV=production node index.js",

    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "framer-motion": "^12.23.26",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.0.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "react-icons": "^5.5.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "cross-env": "^7.0.3"
  }
}